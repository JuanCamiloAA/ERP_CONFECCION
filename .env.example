APP_NAME="MiTallerCol"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Bogota
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=erp_confeccion
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@taller.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
VITE_DEV_SERVER_URL=http://127.0.0.1:5173
VITE_DEV_SERVER_HOST=127.0.0.1

# Firebase / Google Cloud Storage (subidas: logos, fotos, etc.)
# Copiar el JSON de cuenta de servicio a:
#   storage/app/private/firebase/erp-confeccion-firebase-adminsdk-fbsvc-ab5b0d9591.json
# (esa carpeta esta ignorada en Git). En servidor puedes usar una ruta absoluta.
FILESYSTEM_DEFAULT_UPLOAD_DRIVER=firebase
FIREBASE_PROJECT_ID=erp-confeccion
# ID exacto del bucket (Firebase Console > Storage). Si Storage no esta activado, al iniciarlo se crea el bucket.
# Ejemplos: proyecto.appspot.com | proyecto.firebasestorage.app
FIREBASE_STORAGE_BUCKET=erp-confeccion.appspot.com
# Ruta relativa al proyecto o absoluta:
GOOGLE_APPLICATION_CREDENTIALS=storage/app/private/firebase/erp-confeccion-firebase-adminsdk-fbsvc-ab5b0d9591.json
# Solo si no usas archivo: JSON en una linea (no poner aqui la ruta de un archivo).
FIREBASE_CREDENTIALS_JSON=
# Dias de validez de la URL firmada para ver imagenes (max. 7, limite de Google Cloud Storage)
# FIREBASE_SIGNED_URL_TTL_DAYS=7

# Icono de marca (favicon, login sin ?company=): objeto en Storage por defecto App/Logo/mitallepro-icon-dark.png
# BRAND_FIREBASE_ICON_OBJECT=App/Logo/mitallepro-icon-dark.png
# URL fija opcional (evita depender de URL firmada para favicon):
# BRAND_ICON_URL=

INERTIA_USE_SCRIPT_ELEMENT_FOR_INITIAL_PAGE=true
INERTIA_SSR_ENABLED=false
